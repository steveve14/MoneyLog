<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Backup Rules (API 23~30 호환)
    민감한 재무 DB는 자동 백업에서 제외 — 앱 자체 Google Drive 백업으로 관리
-->
<full-backup-content>
    <exclude domain="database" path="moneylog.db" />
    <exclude domain="database" path="moneylog.db-shm" />
    <exclude domain="database" path="moneylog.db-wal" />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
