<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup 규칙 (API 31+)
    민감한 DB 파일은 Google Drive 앱데이터로 직접 관리하므로 자동 백업에서 제외
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="moneylog.db" />
        <exclude domain="database" path="moneylog.db-shm" />
        <exclude domain="database" path="moneylog.db-wal" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="moneylog.db" />
    </device-transfer>
</data-extraction-rules>
