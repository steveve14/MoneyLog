<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 기본: cleartext HTTP 비허용 (HTTPS만 사용) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
