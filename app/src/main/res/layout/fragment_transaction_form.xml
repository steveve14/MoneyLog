<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 헤더: 타이틀 + 닫기 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="거래 추가"
                android:textAppearance="?attr/textAppearanceTitleLarge" />

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="닫기"
                android:src="@drawable/ic_chevron_left_24"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- 거래 유형 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_expense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="지출"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_income"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="수입"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <!-- 금액 입력 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="금액"
            style="@style/Widget.MoneyLog.TextInputLayout"
            app:suffixText="원">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 카테고리 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="카테고리"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="48dp"
            android:clipChildren="true"
            android:clipToPadding="true"
            app:singleSelection="true"
            app:selectionRequired="true" />

        <TextView
            android:id="@+id/tv_expand_categories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="더보기 ▼"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- 날짜 선택 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="날짜"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar_24"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="날짜 선택" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 결제수단 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="결제수단"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="카드"
                style="@style/Widget.Material3.Chip.Filter"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="현금"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_transfer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이체"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_other"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기타"
                style="@style/Widget.Material3.Chip.Filter" />
        </com.google.android.material.chip.ChipGroup>

        <!-- 메모 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="메모 (선택)"
            style="@style/Widget.MoneyLog.TextInputLayout"
            >

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_memo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 고정 거래 등록 -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_recurring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/recurring_toggle_label" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_recurring_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_r_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interval_daily"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_r_weekly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interval_weekly"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_r_monthly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interval_monthly"
                android:checked="true"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_r_yearly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interval_yearly"
                style="@style/Widget.Material3.Chip.Filter" />
        </com.google.android.material.chip.ChipGroup>

        <!-- 저장 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="저장"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            style="@style/Widget.Material3.Button" />

        <!-- 삭제 버튼 (편집 모드에서만 표시) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="@string/delete"
            android:textColor="@color/expense_color"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>
</ScrollView>
