<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface_container_low">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="96dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 헤더 카드: primary 그라디언트 배경, 총 고정 지출 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_theme_primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTHLY COMMITMENT"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="#B0B8FF"
                        android:letterSpacing="0.10" />

                    <TextView
                        android:id="@+id/tv_total_expense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₩0"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tv_item_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 items scheduled this month"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="#C8CBFF"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fixed Expenses 섹션 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fixed Expenses"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnBackground" />

                <TextView
                    android:id="@+id/tv_expense_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ITEMS"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/md_theme_primary"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_expenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />

            <!-- Fixed Income 섹션 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fixed Income"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnBackground" />

                <TextView
                    android:id="@+id/tv_income_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ITEMS"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/md_theme_tertiary"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_incomes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />

            <!-- AI Insight 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_theme_secondary_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦ AI INSIGHT"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_theme_secondary"
                        android:letterSpacing="0.10"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_ai_insight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="고정 지출을 등록하면 AI가 이번 달 여유 예산을 분석해 드립니다."
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/md_theme_on_secondary_container" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_recurring"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="고정 거래 추가"
        app:icon="@drawable/ic_add_24"
        app:iconTint="@color/md_theme_on_primary"
        android:textColor="@color/md_theme_on_primary"
        app:backgroundTint="@color/md_theme_primary"
        app:cornerRadius="999dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
