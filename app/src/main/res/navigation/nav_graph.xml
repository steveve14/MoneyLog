<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <!-- 온보딩: 언어 선택 (최초 1회) -->
    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.moneylog.ui.fragment.OnboardingFragment"
        android:label="Onboarding">

        <action
            android:id="@+id/action_onboarding_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.moneylog.ui.fragment.DashboardFragment"
        android:label="@string/nav_home" />

    <fragment
        android:id="@+id/transactionFragment"
        android:name="com.moneylog.ui.fragment.TransactionFragment"
        android:label="@string/nav_transactions">

        <action
            android:id="@+id/action_transaction_to_form"
            app:destination="@id/transactionFormFragment"
            app:popUpTo="@id/transactionFragment"
            app:popUpToInclusive="false" />

        <action
            android:id="@+id/action_transaction_to_edit"
            app:destination="@id/transactionFormFragment"
            app:popUpTo="@id/transactionFragment"
            app:popUpToInclusive="false">

            <argument
                android:name="transactionId"
                app:argType="long"
                android:defaultValue="0L" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/transactionFormFragment"
        android:name="com.moneylog.ui.fragment.TransactionFormFragment"
        android:label="@string/nav_add">

        <argument
            android:name="transactionId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.moneylog.ui.fragment.StatisticsFragment"
        android:label="@string/nav_statistics" />

    <!-- Phase 3: 반복 거래 관리 -->
    <fragment
        android:id="@+id/recurringFragment"
        android:name="com.moneylog.ui.fragment.RecurringFragment"
        android:label="@string/nav_recurring">

        <action
            android:id="@+id/action_recurring_to_form"
            app:destination="@id/recurringFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/recurringFormFragment"
        android:name="com.moneylog.ui.fragment.RecurringFormFragment"
        android:label="@string/nav_recurring_form">

        <argument
            android:name="recurringId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

    <!-- Phase 2: 카테고리 관리 -->
    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.moneylog.ui.fragment.CategoryFragment"
        android:label="@string/nav_category" />

    <!-- Phase 5: PIN 잠금 -->
    <fragment
        android:id="@+id/pinLockFragment"
        android:name="com.moneylog.ui.fragment.PinLockFragment"
        android:label="PIN" />

    <!-- Phase 5: 설정 -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.moneylog.ui.fragment.SettingsFragment"
        android:label="@string/nav_settings" />

    <!-- Phase 6: AI 요약 -->
    <fragment
        android:id="@+id/aiSummaryFragment"
        android:name="com.moneylog.ui.fragment.AiSummaryFragment"
        android:label="@string/ai_summary_title" />

</navigation>
